model:
  provider: local
  base_url: http://localhost:11434/v1
  api_key: ollama
  model_name: qwen3:8b
  temperature: 0.0

agent:
  max_iterations: 20
  tool_timeout_seconds: 30
  repeated_call_window: 3

tools:
  static:
    - filesystem
    - shell
    - python_exec

mcp:
  servers:
    - name: neo4j
      command: /usr/local/bin/neo4j-mcp
      args: []
      env:
        NEO4J_URI: "${NEO4J_URI}"
        NEO4J_USERNAME: "${NEO4J_USERNAME}"
        NEO4J_PASSWORD: "${NEO4J_PASSWORD}"
    # Optional: vector knowledge base (any MCP-compatible server)
    # - name: vector-kb
    #   command: /path/to/mcp_server
    #   args: []

sandbox:
  timeout_seconds: 15
  max_output_bytes: 65536
  allow_network: false

graph_pipeline:
  context_dir: context/
  default_sample_size: 50
  default_batch_size: 500
  default_model: qwen3:8b

tricentis:
  deployment: "${TAIS_LLM_DEPLOYMENT}"  # set TAIS_LLM_DEPLOYMENT in .env, or pass via --model
